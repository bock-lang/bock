{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bock",
  "scopeName": "source.bock",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#function-declaration" },
    { "include": "#type-identifiers" },
    { "include": "#operators" },
    { "include": "#set-literal" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.module-documentation.bock",
          "match": "//!.*$"
        },
        {
          "name": "comment.line.documentation.bock",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.bock",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bock",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#block-comment-inner" }
          ]
        }
      ]
    },
    "block-comment-inner": {
      "patterns": [
        {
          "name": "comment.block.bock",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#block-comment-inner" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.bock",
          "match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.definition.annotation.bock" },
            "2": { "name": "entity.name.annotation.bock" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.other.raw-triple.bock",
          "begin": "r\"\"\"",
          "end": "\"\"\"",
          "patterns": []
        },
        {
          "name": "string.quoted.triple.bock",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        },
        {
          "name": "string.quoted.other.raw.bock",
          "begin": "r\"",
          "end": "\"",
          "patterns": []
        },
        {
          "name": "string.quoted.double.bock",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "name": "meta.interpolation.bock",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.bock" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.bock" }
      },
      "contentName": "source.bock",
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#characters" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#function-declaration" },
        { "include": "#type-identifiers" },
        { "include": "#operators" },
        { "include": "#punctuation" }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.bock",
          "match": "\\\\[nrt\\\\\"'0$]"
        },
        {
          "name": "constant.character.escape.unicode.bock",
          "match": "\\\\u\\{[0-9a-fA-F]{1,6}\\}"
        },
        {
          "name": "invalid.illegal.escape.bock",
          "match": "\\\\."
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.bock",
          "match": "'(\\\\[nrt\\\\\"'0]|\\\\u\\{[0-9a-fA-F]{1,6}\\}|[^'\\\\])'",
          "captures": {
            "0": { "name": "string.quoted.single.bock" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.bock",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9][0-9_]*)?(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.float.bock",
          "match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.bock",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.octal.bock",
          "match": "\\b0[oO][0-7][0-7_]*(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.binary.bock",
          "match": "\\b0[bB][01][01_]*(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.bock",
          "match": "\\b[0-9][0-9_]*(?:_[a-zA-Z][a-zA-Z0-9_]*)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bock",
          "match": "\\b(?:fn|let|mut|const|if|else|match|for|in|while|loop|break|continue|return|guard|with|handling|handle)\\b"
        },
        {
          "name": "keyword.declaration.bock",
          "match": "\\b(?:record|enum|class|trait|impl|module|use|effect|platform)\\b"
        },
        {
          "name": "keyword.modifier.bock",
          "match": "\\b(?:public|internal|native|async|await|where|type|forall|property)\\b"
        },
        {
          "name": "variable.language.self.bock",
          "match": "\\bself\\b"
        },
        {
          "name": "entity.name.type.self.bock",
          "match": "\\bSelf\\b"
        },
        {
          "name": "constant.language.boolean.bock",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.bock",
          "match": "\\b(?:Ok|Err|Some|None)\\b"
        },
        {
          "name": "keyword.other.bock",
          "match": "\\bunreachable\\b"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "(?<=\\bfn\\s)\\s*([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.bock" }
          }
        }
      ]
    },
    "type-identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.bock",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.bock",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.fat.bock",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.thin.bock",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.inclusive.bock",
          "match": "\\.\\.="
        },
        {
          "name": "keyword.operator.range.bock",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.power.bock",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.compose.bock",
          "match": ">>"
        },
        {
          "name": "keyword.operator.comparison.bock",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.type-test.bock",
          "match": "\\bis\\b"
        },
        {
          "name": "keyword.operator.logical.bock",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.compound.bock",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.assignment.bock",
          "match": "="
        },
        {
          "name": "keyword.operator.bitwise.bock",
          "match": "[&|^~]"
        },
        {
          "name": "keyword.operator.arithmetic.bock",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.question.bock",
          "match": "\\?"
        }
      ]
    },
    "set-literal": {
      "patterns": [
        {
          "name": "punctuation.definition.set.bock",
          "match": "#\\{"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.bock",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.bock",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.bock",
          "match": ";"
        },
        {
          "name": "punctuation.section.braces.begin.bock",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.bock",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.bock",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.bock",
          "match": "\\]"
        },
        {
          "name": "punctuation.section.parens.begin.bock",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.bock",
          "match": "\\)"
        }
      ]
    }
  }
}
