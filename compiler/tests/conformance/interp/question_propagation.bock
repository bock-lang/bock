// TEST: interpreter_question_propagation
// EXPECT: output "ok=4;err=too-big;none;some=3;done"
//
// §7.10 error propagation under the reference interpreter (`bock run`):
// `expr?` on `Err(e)` (and `None`) early-returns the `Err`/`None` from the
// *enclosing function*; the caller observes it as a normal `Result`/`Optional`
// value and execution continues. Same program and same expected line as
// `exec/exec_question_propagation.bock`, which pins the compiled targets —
// the two fixtures together state the interp ≡ targets parity contract
// (Q-interp-question-propagation: the interpreter previously aborted with
// `runtime error: propagated error: too-big` on the first propagated Err).
//
// The end-to-end `bock run` execution of this exact program is asserted by
// `bock-cli/tests/run_command.rs::run_question_propagation_returns_err_to_caller`.
module main

fn parse_small(s: String) -> Result[Int, String] {
  if (s.len() > 3) {
    return Err("too-big")
  }
  Ok(s.len())
}

fn double_len(s: String) -> Result[Int, String] {
  let n = parse_small(s)?
  Ok(n * 2)
}

fn first_or_none(s: String) -> Optional[Int] {
  let n = lookup(s)?
  Some(n + 1)
}

fn lookup(s: String) -> Optional[Int] {
  if (s.len() == 0) {
    return None
  }
  Some(s.len())
}

fn main() -> Void {
  let ok_part = match double_len("ab") {
    Ok(n) => "ok=${n}"
    Err(e) => "ok-err=${e}"
  }
  let err_part = match double_len("toolong") {
    Ok(n) => "err-ok=${n}"
    Err(e) => "err=${e}"
  }
  let none_part = match first_or_none("") {
    Some(n) => "some=${n}"
    None => "none"
  }
  let some_part = match first_or_none("xy") {
    Some(n) => "some=${n}"
    None => "none2"
  }
  println("${ok_part};${err_part};${none_part};${some_part};done")
}
