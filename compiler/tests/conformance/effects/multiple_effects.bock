// TEST: effect_multiple_effects_one_handling_block
// EXPECT: no_errors
// §10.2 / §10.3: a single `handling` block may install handlers for several
// effects at once (comma-separated handler bindings). Here both `Log` and
// `Clock` operations are invoked inside one `handling` block that binds each
// effect to its own record+impl handler, so every effect operation resolves to
// an in-scope Layer-1 handler and the program is well-formed.
module effects_multiple_effects

effect Log {
  fn log(message: String) -> Void
}

effect Clock {
  fn now() -> Int
}

record ConsoleLog {}

impl Log for ConsoleLog {
  fn log(message: String) -> Void {
    println("[log] ${message}")
  }
}

record FixedClock {}

impl Clock for FixedClock {
  fn now() -> Int {
    0
  }
}

fn main() {
  handling (Log with ConsoleLog {}, Clock with FixedClock {}) {
    let t = now()
    log("started at ${t}")
  }
}
