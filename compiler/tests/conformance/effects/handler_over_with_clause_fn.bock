// TEST: effect_handler_over_with_clause_fn
// EXPECT: no_errors
// §10.2 effect propagation + §10.3 Layer-1 resolution: `greet` performs the
// `Log` effect operation `log` and therefore declares `with Log` in its
// signature, deferring handler choice to its caller. `main` installs a concrete
// record+impl handler for `Log` via a `handling` block and calls `greet` inside
// it, so the effect required by `greet` is satisfied by the caller's in-scope
// handler. This is the canonical "handler over a `with`-clause function" case:
// the effect is declared (not handled) at the callee and handled at the caller.
module effects_handler_over_with_clause_fn

effect Log {
  fn log(message: String) -> Void
}

record ConsoleLog {}

impl Log for ConsoleLog {
  fn log(message: String) -> Void {
    println("[log] ${message}")
  }
}

fn greet(name: String) -> Void
  with Log
{
  log("hello, ${name}")
}

fn main() {
  handling (Log with ConsoleLog {}) {
    greet("world")
  }
}
