// TEST: effect_lambda_handler_reserved_v1x
// EXPECT: error E6006 at 21:16
// Section 10.4 Reserved-for-v1.x: v1 supports exactly ONE handler form
// (record + impl). The lambda-based `Effect.handler(...)` constructor surface
// is Reserved for v1.x. The checker recognizes the shape - an unbound
// identifier naming a known effect, used in value position with `.handler` -
// and reports E6006, naming the actual rule with a note stating what v1 DOES
// support: a record + `impl Log for <Record>`, installed via `handle Log
// with <record>` or `handling (Log with <record>) { ... }`. The diagnostic
// spans the whole `Log.handler(...)` expression starting at the `Log`
// reference (21:16) and is emitted exactly ONCE. (Historically: a doubled,
// rule-less `E4002 undefined variable` at the same span; the method-call
// desugar duplicates the receiver node - Q-diag-effect-violation-errors.)
module effects_lambda_handler_reserved

effect Log {
  fn log(message: String) -> Void
}

fn main() {
  let silent = Log.handler(
    log: (message) => {}
  )
}
