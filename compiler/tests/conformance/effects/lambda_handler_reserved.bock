// TEST: effect_lambda_handler_reserved_v1x
// EXPECT: error E1001 at 17:16
// §10.4 Reserved-for-v1.x: v1 supports exactly ONE handler form (record + impl).
// The lambda-based `Effect.handler(...)` constructor surface is Reserved for
// v1.x. In v1 it fails at NAME RESOLUTION because the effect name is not bound
// in the value namespace: the effect `Log` is a type, not a value, so the
// `Log.handler` reference resolves to an undefined name. The expected
// diagnostic is the undefined-name error (E1001, per the resolver) at the
// `Log.handler` reference on the `let silent = ...` line below (17:16).
module effects_lambda_handler_reserved

effect Log {
  fn log(message: String) -> Void
}

fn main() {
  let silent = Log.handler(
    log: (message) => {}
  )
}
