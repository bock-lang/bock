// TEST: list_insert_non_mut_receiver
// EXPECT: error E5004 at 14:3
//
// DQ30: `insert` is an in-place mutator
// (`insert(mut self, index: Int, value: T) -> Void`) — it inserts into the
// receiver, shifting the suffix, so it requires a `mut` receiver exactly like
// DQ18's `push`/`append`. Calling it on a plain (non-`mut`) `let` binding is a
// checker error (`E5004`, the ownership pass) that points at the receiver and
// suggests `let mut`.
module main

fn main() -> Void {
  let xs: List[Int] = [1, 2, 3]
  xs.insert(0, 9)
  println("${xs.len()}")
}
