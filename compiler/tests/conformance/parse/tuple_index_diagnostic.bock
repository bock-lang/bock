// TEST: parse_tuple_index_diagnostic
// EXPECT: error E2092 at 13:4
//
// Tuple positional indexing `t.0` / `t.1` is deferred to v1.x (spec 7.6). The
// parser recognises the `Ident Dot IntLiteral` shape and emits a specific,
// actionable diagnostic (E2092) pointing at destructuring; the span starts at
// the `.` (column 4: two spaces + `t`, then `.`). Driven through `bock check`;
// also asserted by the `bock-parser` unit tests `expr_tuple_index_*`.
// (No multibyte chars in this fixture, so the column is drift-free.)

fn main() -> Int {
  let t = (1, 2)
  t.0
}
