// TEST: exec_self_method
// EXPECT: output "sum=5;scaled=20"
// EXPECT: targets rust, go, python, js, ts
//
// Regression fixture for the codegen-correctness workstream (defect 3):
// instance methods that take `self`. The AIR lowerer desugars `p.m(x)` into
// `Call(FieldAccess(p, m), [p, x])` (self prepended) while keeping `self` as a
// declared parameter. Before the fix:
//   * Rust emitted `fn sum(&self, self: _)` and called `p.sum(p)` -- double self.
//   * Go emitted `func (p *Point) sum(self interface{})` but used `self.X` in
//     the body, and called `p.Sum(p)` -- undefined `self`, extra arg.
//   * Python emitted `def sum(self, self)` and called `p.sum(p)` -- duplicate
//     parameter / extra arg.
//   * TS emitted `Point.prototype.sum = function(self)` with no member on the
//     class type, so `tsc` rejected `p.sum(p)` (method not on `Point`) and
//     flagged `self` as implicit `any` (Q-ts-codegen). The fix emits a
//     declaration-merging `interface Point { sum(self: Point): number; ... }`
//     and types the untyped `self` param as the impl target.
// JS was already self-consistent (explicit `self` param + `p.sum(p)`).
//
// Exercises a method with no extra args (`sum`) and one with an extra arg
// (`scale`) to cover both `args[1..]` empty and non-empty at the call site.
//
// `main` is intentionally NOT `public` (see hello_world.bock for the Go
// entry-point rationale).
module main

record Point {
  x: Int
  y: Int
}

impl Point {
  fn sum(self) -> Int {
    self.x + self.y
  }

  fn scale(self, factor: Int) -> Int {
    (self.x + self.y) * factor
  }
}

fn main() -> Void {
  let p: Point = Point { x: 2, y: 3 }
  println("sum=${p.sum()};scaled=${p.scale(4)}")
}
