// TEST: exec_rust_clone_record_field_reuse
// EXPECT: output "left=hi;right=hi"
// EXPECT: targets js, ts, python, rust, go
//
// Q-rust-clone-insertion-gaps (record-literal field-value reuse). A non-Copy
// value (`String`) bound to a single name is used as the value of TWO record
// fields in one record literal: `Pair { left: tag, right: tag }`. Bock's value
// semantics permit reusing `tag` twice (every other backend copies/aliases
// freely); the Rust backend must insert `.clone()` on the reused field value so
// the second `tag` does not reference a moved-out binding.
//
// Before the fix the Rust emitter routed record-literal field values through
// `emit_expr` (not `emit_call_arg`), so the `reused_*` clone-insertion logic was
// never consulted there and the second `tag` produced E0382 ("use of moved
// value") in the emitted Rust. The other four targets compiled and ran fine,
// pinning that the defect was Rust-codegen-only (the target-agnostic ownership
// model already treats both uses as borrows).
//
// `main` is intentionally NOT `public` (see hello_world.bock for the Go
// entry-point rationale).
module main

record Pair {
  left: String,
  right: String,
}

fn main() -> Void {
  let tag: String = "hi"
  let p: Pair = Pair { left: tag, right: tag }
  println("left=${p.left};right=${p.right}")
}
