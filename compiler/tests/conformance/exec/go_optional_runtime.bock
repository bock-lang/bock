// TEST: exec_go_optional_runtime
// EXPECT: output "got 7;nothing"
// EXPECT: targets go, rust, js, ts
//
// Regression fixture for the codegen-correctness workstream (defect 4):
// `Optional[T]` with `Some`/`None` and an Optional `match`. Go had no Optional
// runtime -- it emitted bare `Some`/`None`/`Optional[int64]` with no definitions
// and a value-switch on `.tag`, so `go run` failed to compile. The fix adds a
// Go runtime prelude (a tagged `__bockOption` + `__bockSome`/`__bockNone`),
// maps `Optional` in `map_type_name`, lowers the `Some`/`None` constructors,
// and dispatches the Optional match on the tag.
//
// TS (Q-ts-codegen): previously TypeScript's Optional *type* lowering
// (`number | null`) disagreed with its tagged-object *value* lowering
// (`{ _tag: "Some", _0: v }` / `{ _tag: "None" }`), so `tsc` rejected it. The
// fix emits a `BockOption<T>` discriminated-union type prelude (mirroring Go's
// `__bockOption`) and maps `Optional[T]` to it, so type and value agree, the
// `switch (o._tag)` match narrows, and the two-variant union is exhaustive.
//
// Still restricted away from python: the Python `Optional`/`Some`/`None`
// runtime is a documented fast-follow (out of scope for this Go-focused defect).
//
// `main` is intentionally NOT `public` (see hello_world.bock for the Go
// entry-point rationale).
module main

fn pick(a: Int, b: Int) -> Int? {
  if (a > 0) {
    return Some(a)
  }
  if (b > 0) {
    return Some(b)
  }
  return None
}

fn describe(o: Int?) -> String {
  match o {
    Some(v) => return "got ${v}"
    None => return "nothing"
  }
}

fn main() -> Void {
  println("${describe(pick(0, 7))};${describe(pick(0, 0))}")
}
