// TEST: exec_list_join_count
// EXPECT: output "a-b-c;3;3"
// EXPECT: targets js, ts, python, rust, go
//
// Read-only `List` built-ins: `join(sep)` (a `String`, on a `List[String]`),
// and the `count`/`length` aliases of `len` (`Int`). `join` is lowered per
// target as `(r).join(sep)` (JS/TS), `(sep).join(r)` (Python), `(r).join(...)`
// (Rust `<[String]>::join`), and an inline `%v`-concatenation (Go); `count` /
// `length` lower identically to `len`.
//
// `main` is intentionally NOT `public`.
module main

fn main() -> Void {
  let words: List[String] = ["a", "b", "c"]
  let joined = words.join("-")
  let cnt = words.count()
  let ln = words.length()
  println("${joined};${cnt};${ln}")
}
