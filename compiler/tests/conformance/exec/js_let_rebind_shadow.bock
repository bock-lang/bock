// TEST: js_let_rebind_shadow
// EXPECT: output "10;7"
// EXPECT: targets js
//
// JS regression guard: re-binding an immutable `let` in one scope (the Bock
// idiom for "update an immutable value", `let acc = …; let acc = f(acc)`)
// shadows the prior binding. JS `const`/`let` reject re-declaration in a single
// block scope, so the js emitter declares the first binding `let` and lowers
// each subsequent same-name binding to a plain assignment (`acc = …`). Before
// the fix this emitted `const acc = …` repeatedly → "Identifier 'acc' has
// already been declared" (the todo-list example's `let list = list.add(…)`).
// `bump` additionally re-binds a *parameter* name (`let n = …`), which is the
// same JS block scope as the parameter, so it too must lower to an assignment.
// Targeted at js because the redeclaration rule is JS-specific.
module main

fn bump(n: Int) -> Int {
  let n = n + 1
  let n = n + 1
  n
}

fn main() -> Void {
  let acc = 1
  let acc = acc + 2
  let acc = acc + 3
  let acc = acc + 4
  println("${acc};${bump(5)}")
}
