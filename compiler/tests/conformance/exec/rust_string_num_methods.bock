// TEST: exec_rust_string_num_methods
// EXPECT: output "slice=ello;cat=abXYde;float=3.5;concat=a-b"
// EXPECT: targets rust
//
// String slicing + numeric conversion + String `+` concatenation for the Rust
// backend, which previously had gaps here:
//
//   - `slice(start, end)` had no Rust lowering (`no method 'slice' for String`);
//     it now lowers to a scalar-index char slice
//     (`.chars().skip(start).take(end-start).collect()`), matching the spec §18.3
//     scalar-count semantics (`len` is the scalar count).
//   - `to_float` on an `Int` had no lowering (`no method 'to_float' for i64`);
//     it now lowers to `(n as f64)`.
//   - `String + String` lowered to a native Rust `+` (`expected &str, found
//     String`); the checker now stamps a `string_concat` marker the Rust backend
//     reads to emit `format!("{}{}", l, r)`.
//
// `targets rust` ONLY: `slice`/`to_float` have no lowering in the js/ts/python/go
// backends yet (they emit `s.slice(...)` / `n.toFloat()`, undefined there) — a
// pre-existing cross-backend gap tracked separately (see PR OPENs). The Rust-only
// restriction keeps this fixture honest about what currently works rather than
// papering over the other backends. (String `+` *does* work on all five; the
// move-reuse fixture exercises the all-five path.)
module main

fn main() -> Void {
  let s = "hello"
  let sliced = s.slice(1, 5)

  let base = "abcde"
  let cat = base.slice(0, 2) + "XY" + base.slice(3, 5)

  let n = 7
  let half = n.to_float() / 2.0

  let a = "a"
  let b = "b"
  let joined = a + "-" + b

  println("slice=${sliced};cat=${cat};float=${half};concat=${joined}")
}
