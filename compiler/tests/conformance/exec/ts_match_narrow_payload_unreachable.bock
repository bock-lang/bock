// TEST: ts_match_narrow_payload_unreachable
// EXPECT: output "id 1;id 2"
// EXPECT: targets ts
//
// Q-ts-match-narrowing regression guard — the examples/real-world/task-api
// blocker, reduced to its core shape. `demo` has TWO consecutive
// statement-position `match`es over a `Result[Task, String]`, exactly like
// `run_demo`'s `create_task → match` sequence, each binding the `Ok` payload and
// passing it to `show(t: Task)`.
//
// Two regressions are pinned here:
//
//  1. Payload narrowing across reachability. Previously each `println` arm of a
//     `Void`-returning function lowered to `return console.log(...)`. That made
//     the FIRST match's arms both `return`, so TS marked the second match
//     unreachable; in that region `switch (r2._tag) { case "Ok": … }` no longer
//     narrowed `r2`, so `r2._0` widened back to the union payload `Task | string`
//     and `show(t)` failed strict `tsc` with TS2345 ("'string | Task' is not
//     assignable to 'Task'"). The emitter now pins each constructor-arm payload
//     binding to the matched member via
//     `const t = (r2 as Extract<typeof r2, { _tag: "Ok" }>)._0;`, which holds
//     regardless of reachability, so the binding never widens.
//
//  2. Statement-position match arms must NOT early-`return`. A statement-position
//     `match` arm's tail is discarded (the `match` is a statement, not the
//     function's value); emitting `return <arm value>` would abort the function
//     after the first match, dropping the second. The arms here write into a
//     shared accumulator, so both matches must run for the full output to print
//     — a `return`-instead-of-discard regression would truncate it to "id 1".
//
// The harness type-checks the scaffolded project with strict `tsc -p .` before
// running, so this fixture compiles (regression 1) and runs to completion
// (regression 2) only with both fixes in place.
//
// Restricted to `ts`: the unreachable-narrowing widening is a TypeScript
// flow-analysis artifact with no analogue on the other backends (js is untyped;
// rust/go/python narrow structurally). `main` is intentionally NOT `public`
// (see hello_world.bock for the Go entry-point rationale).
module main

record Task {
  id: Int
}

fn show(t: Task) -> String {
  "id ${t.id}"
}

fn make(id: Int) -> Result[Task, String] {
  Ok(Task { id: id })
}

fn demo() -> String {
  let mut out = ""
  let r1 = make(1)
  match r1 {
    Ok(t) => out = show(t)
    Err(e) => out = "err ${e}"
  }
  // To TS the early-return shape would make this match unreachable; narrowing on
  // `r2._tag` must still reach `r2._0` — the widening the Extract cast fixes.
  let r2 = make(2)
  match r2 {
    Ok(t) => out = "${out};${show(t)}"
    Err(e) => out = "${out};err ${e}"
  }
  out
}

fn main() -> Void {
  println(demo())
}
