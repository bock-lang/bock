// TEST: exec_list_functional_methods
// EXPECT: output "12;5;6;106;1;3"
// EXPECT: targets js, ts, python, rust, go
//
// Cluster A regression — `List` functional METHODS with a closure over a
// PRIMITIVE element type. `xs.map`/`.filter`/`.reduce`/`.fold`/`.any`/`.find`
// are closure-taking built-ins on `List[T]`; the checker resolves each to a
// typed signature, but codegen previously fell through to the generic
// desugared-self-call path and emitted `xs.map(xs, cb)` — array-not-a-callback
// on TS, "x.map is not a function" on JS, `'list' object has no attribute 'map'`
// on Python, `no method 'map' found for Vec` on Rust, and a `map`-keyword parse
// error on Go. The fix lowers each to the target's native idiom with the closure
// passed once and correctly typed (`recv.map(cb)` on JS/TS, `list(map(cb,
// recv))` on Python, `recv.iter().map(cb).collect()` on Rust, a `for`-range
// func literal on Go).
//
// Over xs = [1, 2, 3], the printed `;`-joined fields are:
//   map(*2).reduce(+)   = [2,4,6] -> 12
//   filter(>1).reduce(+)= [2,3]   -> 5
//   reduce(+)           = 6
//   fold(100, +)        = 106
//   any(>2) ? 1 : 0     = 1     (Bool stringified as 1/0 so Python's "True"
//                                does not diverge from JS/Go's "true")
//   find(>2) or -1      = 3
//
// Bools are reduced to 0/1 because Python prints `True`/`False` while the other
// targets print `true`/`false`; the harness compares stdout verbatim.
//
// `main` is intentionally NOT `public`.
module main

fn boolToInt(b: Bool) -> Int {
  if (b) {
    return 1
  } else {
    return 0
  }
}

fn optOr(o: Int?, dflt: Int) -> Int {
  match o {
    Some(x) => return x
    None => return dflt
  }
}

fn main() -> Void {
  let xs: List[Int] = [1, 2, 3]

  let doubled: List[Int] = xs.map((n) => n * 2)
  let doubledSum: Int = doubled.reduce((a, b) => a + b)

  let big: List[Int] = xs.filter((n) => n > 1)
  let bigSum: Int = big.reduce((a, b) => a + b)

  let total: Int = xs.reduce((a, b) => a + b)
  let folded: Int = xs.fold(100, (acc, x) => acc + x)

  let hasBig: Int = boolToInt(xs.any((n) => n > 2))
  let firstBig: Int = optOr(xs.find((n) => n > 2), 0 - 1)

  println("${doubledSum};${bigSum};${total};${folded};${hasBig};${firstBig}")
}
