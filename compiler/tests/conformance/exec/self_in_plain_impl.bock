// TEST: exec_self_in_plain_impl
// EXPECT: output "12"
// EXPECT: targets js, ts, python, rust, go
//
// `Self`-in-plain-impl (codegen-completeness; folds OPEN #141): a plain
// inherent `impl` method that names the `Self` type in return position (a
// constructor-style `combine` returning `Self`). Runs on ALL FIVE targets.
//
// Go (P3, #144): before the fix Go set `go_self_subst` only for trait-impl
// (value-receiver) methods, so an inherent-impl `Self` lowered to the
// placeholder `/* Self */`, producing uncompilable Go (`func(...) /* Self */`).
// The fix sets `go_self_subst` to the receiver type for ALL impl methods.
//
// TS (P4): TS lowered `Self` to the `this` type, but the impl methods are
// assigned as `Counter.prototype.x = function(...): this { … }`, and `tsc` only
// permits a `this` type inside a class/interface member, so it rejected the
// assignment (TS2526). The fix sets `trait_self_subst` to the concrete target
// for ALL impl methods (both the merged-interface signature and the prototype
// function), so `Self` renders as `Counter`. Mirrors the Go fix.
//
// js/python/rust resolve a `Self` return type in inherent impls already (Rust
// lowers it to its native `Self`).
//
// `main` is intentionally NOT `public`.
module main

record Counter {
  value: Int
}

impl Counter {
  fn combine(self, other: Counter) -> Self {
    return Counter { value: self.value + other.value }
  }

  fn get(self) -> Int {
    return self.value
  }
}

fn main() -> Void {
  let a: Counter = Counter { value: 5 }
  let b: Counter = Counter { value: 7 }
  let c: Counter = a.combine(b)
  println("${c.get()}")
}
