// TEST: exec_int_mod_sign
// EXPECT: output "2;-2;2;-2"
// EXPECT: targets js, ts, python, rust, go
//
// DQ23 (§3.6): `%` is the remainder of the **truncated** division and takes the
// sign of the **dividend** (C/Rust/Go convention), in lockstep with the
// truncate-toward-zero direction of `/`. The four cases pin the sign: `17%5==2`,
// `-17%5==-2`, `17%-5==2`, `-17%-5==-2`. Python's native `%` follows *floor*
// division (`-17 % 5 == 3`), so a naive Python lowering fails here — the trap
// this fixture guards. Division and modulo are one coherent pair.
//
// Operands flow through `opaque` so the remainder is computed at runtime, not
// folded.
//
// `main` is intentionally NOT `public`.
module main

fn opaque(n: Int) -> Int {
  return n
}

fn main() -> Void {
  let a: Int = opaque(17)
  let b: Int = opaque(5)
  let na: Int = opaque(-17)
  let nb: Int = opaque(-5)
  println("${a % b};${na % b};${a % nb};${na % nb}")
}
