// TEST: eq_enum_variants
// EXPECT: output "unit:true;cross:false;payload:true;payload_ne:false;mixed:false"
// EXPECT: targets js, ts, python, rust, go
//
// DQ29 (§18.5 structural Equatable): an enum whose variant payloads are all
// Equatable conforms structurally. Equality is tag-then-payload: unit variants
// compare by tag alone; payload variants compare the tag first, then each
// payload component; values of different variants are never equal.
//
// Codegen contract pinned here: JS tagged payload objects are freshly
// allocated per construction, so `===` (reference) would wrongly report two
// equal `Mix(1, 2)` values unequal; Rust enums need `PartialEq`.
//
// `main` is intentionally NOT `public` (see hello_world.bock for the Go
// entry-point rationale).
module main

enum Color {
  Red,
  Green,
  Mix(Int, Int),
}

fn main() -> Void {
  let u1: Color = Red
  let u2: Color = Red
  let g: Color = Green
  let m1: Color = Mix(1, 2)
  let m2: Color = Mix(1, 2)
  let m3: Color = Mix(1, 3)
  let unit: Bool = u1 == u2
  let cross: Bool = u1 == g
  let payload: Bool = m1 == m2
  let payload_ne: Bool = m1 == m3
  let mixed: Bool = u1 == m1
  println("unit:${unit};cross:${cross};payload:${payload};payload_ne:${payload_ne};mixed:${mixed}")
}
