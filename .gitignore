# Rust
/target/
**/*.rs.bk
Cargo.lock.bak

# Bock build cache
.bock/

# Example build output — project-mode `bock build` emits a regenerable
# per-target tree (sources, manifests, compiled artifacts) under
# examples/**/build/. Never commit it; it is reproduced by building.
examples/**/build/

# Node / VS Code extension
node_modules/
*.vsix
extensions/*/out/
extensions/*/dist/
extensions/*/.vscode-test/

# mdBook
docs/book/

# Website build output
website/dist/
website/.next/
website/node_modules/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Local-only Claude Code settings
.claude/settings.local.json

# Env
.env
.env.local
.env.*.local

# Python build artifacts
tools/pypi-placeholder/dist/
tools/pypi-placeholder/build/
tools/pypi-placeholder/src/*.egg-info/

# Node/npm build artifacts
tools/npm-placeholder/node_modules/
tools/npm-placeholder/*.tgz
tools/npm-placeholder/package-lock.json

# Branding related: explicit allow
branding/*
!branding/assets/

temp/
